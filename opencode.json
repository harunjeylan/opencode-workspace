{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "web-search": {
      "type": "local",
      "command": ["npx", "-y", "open-websearch@latest"],
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo"
      },
      "enabled": true
    }
  },
  "plugin": ["opencode-wakatime", "@zenobius/opencode-skillful"]
}
